# Copy to .env and fill in values
PCE_DB_PATH=data/pce.db
PCE_DATA_DIR=data

# Comma-separated list of directories to watch and ingest
# PCE_WATCH_DIRS=["~/code/my-project", "~/Documents/notes"]

# LLM backend: "ollama" or "anthropic"
PCE_LLM_BACKEND=ollama
PCE_OLLAMA_BASE_URL=http://localhost:11434
PCE_OLLAMA_MODEL=llama3.2

# Only needed if using Anthropic
# PCE_ANTHROPIC_API_KEY=sk-ant-...
# PCE_ANTHROPIC_MODEL=claude-sonnet-4-6

PCE_LOG_LEVEL=INFO
